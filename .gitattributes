# Auto detect text files and perform LF normalization
* text=auto

# Source files
*.ts text
*.tsx text
*.js text
*.jsx text
*.css text
*.json text
*.md text
*.html text
*.svg text

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary

# Archives
*.zip binary
*.tar binary
*.gz binary

# Exclude files from export
.gitattributes export-ignore
.gitignore export-ignore
.github export-ignore
.devcontainer export-ignore
.spark-workbench-id export-ignore
.spark-initial-sha export-ignore
.file-manifest export-ignore
